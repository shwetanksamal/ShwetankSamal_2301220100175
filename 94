class Solution:
    def inorderTraversal(self, root: Optional[TreeNode]) -> List[int]:
        cur = root
        l = []

        while cur is not None:
            if cur.left is None:
                l.append(cur.val)
                cur = cur.right
            else:
                pre = cur.left

                while pre.right is not None and pre.right != cur:
                    pre = pre.right

                if pre.right is None:
                    pre.right = cur
                    cur = cur.left
                else:
                    pre.right = None
                    l.append(cur.val)
                    cur = cur.right

        return l
